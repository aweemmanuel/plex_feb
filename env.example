# ─────────────────────────────────────────────────────
#  Plex + rclone + WebDAV — Railway Environment Template
#  Copy these into your Railway service → Variables tab
# ─────────────────────────────────────────────────────

# ── WebDAV / FebBox ─────────────────────────────────
WEBDAV_URL=https://webdav.febbox.com/dav
WEBDAV_USER=your@email.com
WEBDAV_PASS=your_password_or_token
WEBDAV_VENDOR=other

# ── rclone ──────────────────────────────────────────
RCLONE_REMOTE_NAME=febbox
MOUNT_PATH=/mnt/febbox
LOCAL_MEDIA_PATH=/data/media

# ── Plex ────────────────────────────────────────────
# Get claim token from: https://www.plex.tv/claim (expires in 4 min)
PLEX_CLAIM=claim-xxxxxxxxxxxxxxxxxxxx
# Get token from Plex web → Settings → Account → XML → X-Plex-Token
PLEX_TOKEN=
PLEX_HOST=localhost
PLEX_PORT=32400
PLEX_TRANSCODE_DIR=/transcode
PLEX_CONFIG_DIR=/config/plex

# ── Sync Mode ───────────────────────────────────────
# "sync" = stable (recommended for Railway)
# "mount" = real-time (may disconnect on Railway)
SYNC_MODE=sync
SYNC_INTERVAL=10

# ── Timezone ────────────────────────────────────────
TZ=Africa/Lagos
